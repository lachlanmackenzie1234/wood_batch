cat > .gitignore <<'EOF'
# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Generated output
output/*
!output/.gitkeep

# Local/system files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/

# Logs
*.log

# Optional: large production/test images
# Uncomment these if you do not want to commit test/source images.
# images/*
# example_output/*
